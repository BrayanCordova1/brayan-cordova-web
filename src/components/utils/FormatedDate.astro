---
interface Props {
  date: Date | string | undefined;
}

const {date} = Astro.props;
const finalDate = typeof date === "string" ? new Date(date) : date;
---

<time datetime={finalDate?.toISOString()}>
  {
    finalDate?.toLocaleDateString("es", {
      year: "numeric",
      month: "long",
      day: "numeric",
    })
  }
</time>
